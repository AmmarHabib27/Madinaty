SECRET_KEY=your-secret-key-here
ENVIRONMENT=production  # options: production, staging
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite default)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=madinaty_main
DB_USER=postgres
DB_PASSWORD=126423
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOW_ALL_ORIGINS=False

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@madinaty.com

# OneSignal push notifications
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# JWT token lifetimes (in minutes)
ACCESS_TOKEN_LIFETIME_MINUTES=1440
REFRESH_TOKEN_LIFETIME_MINUTES=43200

# Timezone
TIME_ZONE=Africa/Cairo
